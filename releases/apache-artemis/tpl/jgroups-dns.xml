<config xmlns="urn:org:jgroups"
        xmlns:xsi="http://w3.org"
        xsi:schemaLocation="urn:org:jgroups http://jgroups.org">
    
    <TCP bind_port="7800" />
    <!-- DNS_PING replaces UDP/TCPPING -->
    <dns.DNS_PING
        dns_query="artemis-headless-service.my-namespace.svc.cluster.local"
        dns_record_type="A" /> 
    <MERGE3 />
    <FD_SOCK />
    <FD_ALL />
    <VERIFY_SUSPECT />
    <pbcast.NAKACK2 />
    <pbcast.STABLE />
    <pbcast.GMS />
    <MFC />
    <FRAG2 />
</config>
